# =============================================
# 기본 Chainlit 챗봇 - 환경 변수 설정 예시
# =============================================
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요
# cp .env.example .env

# OpenAI API 키 (필수)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-your-openai-api-key-here

# 사용할 OpenAI 모델 (선택, 기본값: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
