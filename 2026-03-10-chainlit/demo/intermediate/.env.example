# =============================================
# 중급 Chainlit 챗봇 - 환경 변수 설정 예시
# =============================================
# 이 파일을 복사하여 .env 파일을 생성하세요
# cp .env.example .env

# OpenAI API 키 (필수)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-your-openai-api-key-here

# 사용할 OpenAI 모델 (선택, 기본값: gpt-4o)
# 파일 분석에는 gpt-4o 권장 (비전 기능 지원)
OPENAI_MODEL=gpt-4o

# 인증 관련 설정 (선택)
# CHAINLIT_AUTH_SECRET은 JWT 서명에 사용됩니다 (프로덕션에서 필수)
# python -c "import secrets; print(secrets.token_hex(32))" 로 생성 가능
CHAINLIT_AUTH_SECRET=your-secret-key-here

# 어드민 계정 설정 (데모용)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
