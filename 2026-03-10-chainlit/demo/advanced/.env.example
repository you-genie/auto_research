# =============================================
# 고급 Chainlit + LangGraph 멀티 에이전트 챗봇
# 환경 변수 설정 예시
# =============================================
# 이 파일을 복사하여 .env 파일을 생성하세요
# cp .env.example .env

# -----------------------------------------------
# [필수] OpenAI API 키
# https://platform.openai.com/api-keys 에서 발급
# -----------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# 사용할 OpenAI 모델 (권장: gpt-4o - 도구 호출 지원)
OPENAI_MODEL=gpt-4o

# -----------------------------------------------
# [선택] Tavily Search API 키 (웹 검색 도구용)
# https://tavily.com/ 에서 무료 발급 가능
# 없으면 웹 검색 도구가 비활성화됩니다
# -----------------------------------------------
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# -----------------------------------------------
# [선택] OpenWeatherMap API 키 (날씨 도구용)
# https://openweathermap.org/api 에서 무료 발급
# 없으면 날씨 도구가 비활성화됩니다
# -----------------------------------------------
OPENWEATHER_API_KEY=your-openweather-api-key-here

# -----------------------------------------------
# [선택] Chainlit 인증 시크릿 (프로덕션 필수)
# python -c "import secrets; print(secrets.token_hex(32))" 으로 생성
# -----------------------------------------------
CHAINLIT_AUTH_SECRET=your-secret-key-minimum-32-chars

# -----------------------------------------------
# [선택] LangSmith 트레이싱 (디버깅/모니터링용)
# https://smith.langchain.com/ 에서 가입 후 발급
# -----------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your-langsmith-api-key-here
# LANGCHAIN_PROJECT=chainlit-multiagent-demo
